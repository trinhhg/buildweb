## Render list hiệu quả

```javascript
function renderItems(items) {
  const container = document.getElementById("list");
  if (!items.length) {
    container.innerHTML = `<p class="text-center text-slate-400 p-6">Không có dữ liệu</p>`;
    return;
  }
  container.innerHTML = items.map((item, i) => `
    <div class="border-b p-3 flex items-center gap-2">
      <span class="text-slate-400 text-xs w-6">${i + 1}</span>
      <span class="flex-1 font-bold">${item.name}</span>
      <button onclick="editItem('${item.id}')" class="text-xs bg-indigo-50 text-indigo-600 px-2 py-1 rounded">Sửa</button>
    </div>
  `).join("");
}
```
