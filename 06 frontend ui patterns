## State management đơn giản

```javascript
// Dùng plain objects — không cần Redux/Zustand
let appState = { user: null, items: [], loading: false };

// Render lại khi state thay đổi
function setState(patch) {
  Object.assign(appState, patch);
  render(); // re-render affected component
}
```

## localStorage cache pattern

```javascript
// Đọc có fallback
function loadCache(key, def = []) {
  try { return JSON.parse(localStorage.getItem(key)) || def; }
  catch { return def; }
}
// Ghi
const saveCache = (key, val) => localStorage.setItem(key, JSON.stringify(val));
```

## API call pattern — GET + POST

```javascript
// GET với cache fallback (trang vẫn hoạt động khi offline)
async function apiFetch(path, def = null) {
  try {
    const r = await fetch(path + "?_=" + Date.now());
    if (!r.ok) throw new Error(r.status);
    const data = await r.json();
    saveCache(path, data);
    return data;
  } catch {
    return loadCache(path) ?? def;
  }
}

// POST
async function apiPost(path, body) {
  saveCache(path, body); // optimistic update
  try {
    await fetch(path, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
  } catch (e) {
    console.warn("POST failed, cached locally:", e);
  }
}
```

## Toast notification

```javascript
function toast(msg, type = "ok") {
  const colors = { ok: "bg-emerald-500", err: "bg-red-500", warn: "bg-amber-500" };
  const el = document.createElement("div");
  el.className = `fixed top-4 right-4 z-50 px-4 py-3 rounded-xl text-white font-bold text-sm
                  ${colors[type] || colors.ok} transition-all`;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 2500);
}
```

## Modal pattern

```javascript
const openModal = id => document.getElementById(id).classList.remove("hidden");
const closeModal = id => document.getElementById(id).classList.add("hidden");
```

```html
<!-- Modal HTML chuẩn -->
<div id="myModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
    <!-- content -->
    <button onclick="closeModal('myModal')">Đóng</button>
  </div>
</div>
```

## Copy to clipboard

```javascript
const copyText = text => {
  navigator.clipboard.writeText(text).catch(() => {});
  toast("✅ Đã copy!");
};
```

## Tab switching

```javascript
const TABS = ["tab-a", "tab-b", "tab-c"];
function switchTab(id) {
  TABS.forEach(t => {
    document.getElementById(t).classList.add("hidden");
    document.getElementById("btn-" + t).classList.remove("active");
  });
  document.getElementById(id).classList.remove("hidden");
  document.getElementById("btn-" + id).classList.add("active");
}
```

